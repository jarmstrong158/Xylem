# Xylem backups written by the installers.
# *.xylem-backup  -> root installer.py (pristine, first write)
# *.xylem-backup.<epoch> -> root installer.py (preserved hand edit)
# *.bak-<timestamp>      -> install/xylem_install.py (per-apply)
# These normally live under $HOME, but a --project install drops one inside the
# user's own repo, where their .gitignore won't have the pattern.
*.xylem-backup
*.xylem-backup.*
*.bak-[0-9]*

# Local untracked config (never commit URLs or secrets)
# The installer reads xylem.config.json and the example tells users to put their
# /mcp/<token> connector URLs (whole-URL credentials) there — must stay ignored.
xylem.config.json
install/xylem.config.json
xylem.local.json
.env
.env.*

# Python
__pycache__/
*.pyc
.pytest_cache/

# Context-keeper local memory store (machine-local, never commit)
.context/
.cambium/
